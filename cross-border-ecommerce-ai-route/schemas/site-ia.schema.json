{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.zhineng/cross-border-ecommerce/schemas/site-ia.schema.json",
  "title": "Cross-Border Ecommerce Site IA",
  "type": "object",
  "required": ["contract", "site_goal", "navigation", "product_page_contract", "rfq_contract", "publish_gate"],
  "additionalProperties": false,
  "properties": {
    "contract": { "const": "structured_cabling_site_ia.v1" },
    "site_goal": { "type": "string" },
    "primary_markets": { "type": "array", "items": { "type": "string" } },
    "navigation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path", "purpose"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "path": { "type": "string" },
          "purpose": { "type": "string" },
          "children": { "type": "array", "items": { "type": "object" } }
        }
      }
    },
    "product_page_contract": {
      "type": "object",
      "required": ["required_sections", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "required_sections": { "type": "array", "items": { "type": "string" } },
        "required_fields": { "type": "array", "items": { "type": "string" } },
        "structured_data": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rfq_contract": {
      "type": "object",
      "required": ["required_fields", "family_dynamic_fields"],
      "additionalProperties": false,
      "properties": {
        "required_fields": { "type": "array", "items": { "type": "string" } },
        "family_dynamic_fields": { "type": "object" }
      }
    },
    "publish_gate": {
      "type": "object",
      "required": ["human_review_required", "blocked_if_old_brand_visible", "blocked_if_unverified_claims"],
      "additionalProperties": false,
      "properties": {
        "human_review_required": { "type": "boolean" },
        "blocked_if_old_brand_visible": { "type": "boolean" },
        "blocked_if_unverified_claims": { "type": "boolean" }
      }
    }
  }
}
