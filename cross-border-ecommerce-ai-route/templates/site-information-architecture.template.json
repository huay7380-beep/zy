  "product_page_contract": {
    "required_sections": [
      "hero",
      "key_specs",
      "variant_matrix",
      "application",
      "downloads",
      "related_products",
      "rfq_cta",
      "faq"
    ],
    "required_fields": [
      "public_sku",
      "product_family",
      "grade",
      "shielding",
      "ports_or_size",
      "material",
      "moq",
      "lead_time",
      "certificate_request_policy"
    ],
    "structured_data": ["Product", "BreadcrumbList", "FAQPage"]
  },
  "rfq_contract": {
    "required_fields": ["company", "contact_name", "email", "country", "product_family", "quantity", "message"],
    "family_dynamic_fields": {
      "keystone_jack": ["grade", "shielding", "termination", "color"],
      "patch_panel": ["ports", "rack_unit", "grade", "shielding", "loaded_or_blank"],
      "plug_patch_cord": ["grade", "shielding", "length", "jacket", "color"],
      "power_distribution_unit": ["target_country", "plug_country_type", "rated_voltage", "rated_current"]
    }
  },
  "publish_gate": {
    "human_review_required": true,
    "blocked_if_old_brand_visible": true,
    "blocked_if_unverified_claims": true
  }
