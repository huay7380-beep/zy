{
  "schema_version": "0.1.0",
  "project_id": "cross_border_ecommerce_ai_route",
  "nodes": [
    {
      "node_id": "cbx_00_strategy_scope",
      "label": "经营策略与范围确认",
      "layer": "strategy",
      "purpose": "确认业务模式、目标市场、产品线、首期闭环和不可自动执行边界。",
      "owner_role": "operator",
      "status": "draft",
      "source_docs": ["docs/00-overview.md", "docs/09-roadmap-acceptance.md"],
      "inputs": ["product_source_summary", "business_goal", "target_market_hypotheses", "budget_limit"],
      "outputs": ["strategy_scope.v1", "first_phase_success_metrics.v1", "blocked_assumptions.v1"],
      "control_actions": ["draft_scope", "review_market_modes", "set_phase_gate"],
      "required_human_gates": ["confirm_business_mode", "confirm_target_markets", "confirm_budget"],
      "event_writeback": ["strategy_decision_recorded"],
      "audit_evidence": ["scope_document", "decision_log"]
    },
    {
      "node_id": "cbx_01_entity_compliance",
      "label": "大陆主体与证照准备",
      "layer": "compliance",
      "purpose": "形成营业执照、银行、税务、海关、电子口岸、外汇、ICP 和数据合规清单。",
      "owner_role": "finance_compliance",
      "status": "draft",
      "source_docs": ["docs/01-mainland-compliance.md", "docs/sources.md"],
      "inputs": ["company_profile", "business_license", "bank_account_status", "tax_status"],
      "outputs": ["company_export_readiness.v1", "missing_license_tasks.v1", "website_data_compliance_gate.v1"],
      "control_actions": ["build_license_checklist", "generate_filing_pack_draft", "flag_professional_review"],
      "required_human_gates": ["legal_review", "tax_review", "bank_fx_review"],
      "event_writeback": ["entity_readiness_checked", "license_blocker_found"],
      "audit_evidence": ["license_matrix", "review_notes"]
    },
    {
      "node_id": "cbx_02_product_compliance",
      "label": "产品合规与目标国准入",
      "layer": "compliance",
      "purpose": "为每个 SKU 建立 HS code、目标国认证、标签、包装、知识产权和禁限售风险档案。",
      "owner_role": "product_compliance",
      "status": "draft",
      "source_docs": ["docs/01-mainland-compliance.md", "docs/06-fulfillment-finance-after-sales.md"],
      "inputs": ["product_master_draft", "product_images", "materials", "use_case", "target_country"],
      "outputs": ["product_compliance_matrix.v1", "hs_code_candidate_review.v1", "target_market_entry_gate.v1"],
      "control_actions": ["draft_compliance_matrix", "request_certificates", "block_unverified_claims"],
      "required_human_gates": ["hs_code_review", "certification_review", "ip_review"],
      "event_writeback": ["product_compliance_profile_updated"],
      "audit_evidence": ["certificate_files", "classification_notes", "label_requirements"]
    },
    {
      "node_id": "cbx_03_market_selection",
      "label": "目标市场与客户画像",
      "layer": "strategy",
      "purpose": "选择首期国家、客户类型、采购场景和进入顺序。",
      "owner_role": "growth_operator",
      "status": "draft",
      "source_docs": ["docs/00-overview.md", "docs/04-acquisition-and-promotion.md"],
      "inputs": ["product_compliance_matrix", "margin_model", "shipping_constraints", "competitor_notes"],
      "outputs": ["market_priority_matrix.v1", "ideal_customer_profile.v1", "channel_priority.v1"],
      "control_actions": ["score_markets", "draft_icp", "select_channels"],
      "required_human_gates": ["confirm_market_priority"],
      "event_writeback": ["market_decision_recorded"],
      "audit_evidence": ["market_scorecard", "source_links"]
    },
    {
      "node_id": "cbx_04_independent_site",
      "label": "独立站与询盘入口",
      "layer": "site",
      "purpose": "设计独立站结构、RFQ 表单、B2B 信任页面、隐私条款和事件采集。",
      "owner_role": "site_operator",
      "status": "draft",
      "source_docs": ["docs/02-independent-site-and-data.md"],
      "inputs": ["market_priority_matrix", "product_master", "brand_assets", "rfq_fields"],
      "outputs": ["site_map.v1", "rfq_form_contract.v1", "site_event_plan.v1"],
      "control_actions": ["draft_site_map", "draft_rfq_form", "validate_tracking_plan"],
      "required_human_gates": ["approve_site_platform", "approve_privacy_terms", "approve_publish"],
      "event_writeback": ["site_structure_confirmed", "rfq_form_updated"],
      "audit_evidence": ["site_map", "tracking_plan", "terms_review"]
    },
    {
      "node_id": "cbx_05_content_assets",
      "label": "产品内容与图片视频",
      "layer": "content",
      "purpose": "把产品源头资料转成英文产品页、图片、视频、规格书和资料包。",
      "owner_role": "content_operator",
      "status": "draft",
      "source_docs": ["docs/03-product-content-photo.md", "docs/21-ai-driven-product-page-branch.md"],
      "inputs": ["raw_product_specs", "raw_photos", "certificates", "factory_evidence", "universal_product_intake.v1", "reference_page", "brand_policy"],
      "outputs": ["product_content_kit.v1", "photo_shot_list.v1", "site_content_draft.v1", "product_page_build_pack.v1", "source_product_catalog_import.v1", "molex_style_site_draft.v1", "customer_chat_widget_plan.v1"],
      "control_actions": ["generate_shot_list", "draft_product_copy", "check_asset_quality", "import_source_website_products", "run_product_page_ai_build", "generate_product_page_review_pack"],
      "required_human_gates": ["verify_product_claims", "approve_ai_generated_assets", "approve_product_page_strategy", "approve_publish"],
      "event_writeback": ["product_content_ready", "asset_quality_issue_found"],
      "audit_evidence": ["original_assets", "edited_assets", "copy_review"]
    },
    {
      "node_id": "cbx_06_catalog_pricing",
      "label": "产品目录、成本与价格本",
      "layer": "commercial",
      "purpose": "建立 ProductMaster、PriceBook、MOQ、数量阶梯价、成本、毛利和交期规则。",
      "owner_role": "sales_ops",
      "status": "draft",
      "source_docs": ["docs/02-independent-site-and-data.md", "docs/05-inquiry-quote-sales.md"],
      "inputs": ["product_master", "cost_data", "inventory_or_capacity", "target_margin"],
      "outputs": ["price_book.v1", "cost_model.v1", "catalog_export.v1"],
      "control_actions": ["draft_price_book", "validate_margin_floor", "flag_missing_cost"],
      "required_human_gates": ["approve_cost_model", "approve_price_book"],
      "event_writeback": ["price_book_updated", "cost_blocker_found"],
      "audit_evidence": ["cost_source", "margin_policy"]
    },
    {
      "node_id": "cbx_07_acquisition",
      "label": "获客与推广",
      "layer": "growth",
      "purpose": "规划 SEO、Google、LinkedIn、Meta、邮件、WhatsApp、展会和 B2B 平台获客动作。",
      "owner_role": "growth_operator",
      "status": "draft",
      "source_docs": ["docs/04-acquisition-and-promotion.md"],
      "inputs": ["ideal_customer_profile", "site_pages", "campaign_budget", "content_assets"],
      "outputs": ["campaign_plan.v1", "keyword_map.v1", "outreach_draft_pack.v1", "weekly_growth_report.v1"],
      "control_actions": ["draft_campaigns", "generate_ad_copy", "draft_outreach", "analyze_channel_report"],
      "required_human_gates": ["approve_ad_budget", "approve_real_outreach_send"],
      "event_writeback": ["campaign_created", "lead_source_performance_updated"],
      "audit_evidence": ["campaign_plan", "spend_report", "utm_rules"]
    },
    {
      "node_id": "cbx_08_lead_capture",
      "label": "线索捕获与 CRM 入库",
      "layer": "sales",
      "purpose": "把 RFQ、广告表单、邮箱、WhatsApp、展会名片和平台询盘转换为可评分线索。",
      "owner_role": "sales_ops",
      "status": "draft",
      "source_docs": ["docs/02-independent-site-and-data.md", "docs/04-acquisition-and-promotion.md"],
      "inputs": ["rfq_submit", "lead_form", "email_message", "chat_message", "chat_message_draft.v1", "business_card"],
      "outputs": ["lead_record.v1", "lead_score.v1", "dedupe_candidate.v1"],
      "control_actions": ["normalize_lead", "score_lead", "dedupe_customer", "assign_owner"],
      "required_human_gates": ["confirm_high_value_customer_identity"],
      "event_writeback": ["lead_created", "lead_scored", "customer_identity_linked"],
      "audit_evidence": ["source_snapshot", "consent_record", "lead_score_reason"]
    },
    {
      "node_id": "cbx_09_inquiry_reception",
      "label": "询盘接待与需求澄清",
      "layer": "sales",
      "purpose": "识别客户需求、缺口、紧急度和首响草案。",
      "owner_role": "sales_rep",
      "status": "draft",
      "source_docs": ["docs/05-inquiry-quote-sales.md", "docs/08-customer-ai-examples.md"],
      "inputs": ["lead_record", "inquiry_message", "product_master", "customer_history"],
      "outputs": ["inquiry_intake.v1", "first_response_draft.v1", "missing_questions.v1"],
      "control_actions": ["parse_inquiry", "draft_first_response", "schedule_followup"],
      "required_human_gates": ["approve_first_external_reply"],
      "event_writeback": ["inquiry_received", "response_drafted", "followup_scheduled"],
      "audit_evidence": ["original_message", "parsed_fields", "draft_review"]
    },
    {
      "node_id": "cbx_10_quote_engine",
      "label": "报价测算与报价草案",
      "layer": "sales",
      "purpose": "基于产品、成本、价格本、运费、条款和客户风险生成报价草案。",
      "owner_role": "sales_ops",
      "status": "draft",
      "source_docs": ["docs/05-inquiry-quote-sales.md", "templates/quotation.template.md"],
      "inputs": ["inquiry_intake", "product_master", "price_book", "cost_model", "logistics_quote", "customer_risk"],
      "outputs": ["quote_draft.v1", "quote_gate_report.v1", "quote_followup_plan.v1"],
      "control_actions": ["calculate_quote", "validate_quote_gate", "draft_quote_email"],
      "required_human_gates": ["approve_price", "approve_terms", "approve_quote_send"],
      "event_writeback": ["quote_drafted", "quote_blocked", "quote_sent_after_confirmation"],
      "audit_evidence": ["price_source", "logistics_source", "margin_check", "human_approval"]
    },
    {
      "node_id": "cbx_11_contract_payment",
      "label": "合同、PI 与收款",
      "layer": "finance",
      "purpose": "生成 PI/合同/付款说明草案并跟踪收款、风控和外汇资料。",
      "owner_role": "finance_sales",
      "status": "draft",
      "source_docs": ["docs/01-mainland-compliance.md", "docs/06-fulfillment-finance-after-sales.md"],
      "inputs": ["quote_acceptance", "customer_account", "payment_terms", "bank_account", "risk_review"],
      "outputs": ["proforma_invoice_draft.v1", "sales_contract_draft.v1", "payment_status.v1"],
      "control_actions": ["draft_pi", "draft_contract", "track_payment", "flag_payment_risk"],
      "required_human_gates": ["approve_pi", "approve_contract", "approve_payment_instruction"],
      "event_writeback": ["pi_drafted", "payment_pending", "payment_received"],
      "audit_evidence": ["pi_file", "contract_file", "bank_receipt", "risk_notes"]
    },
    {
      "node_id": "cbx_12_order_fulfillment",
      "label": "订单、生产、QC 与物流",
      "layer": "fulfillment",
      "purpose": "把确认订单推进到生产/备货、质检、包装、物流订舱和到货。",
      "owner_role": "operations",
      "status": "draft",
      "source_docs": ["docs/06-fulfillment-finance-after-sales.md"],
      "inputs": ["paid_order", "product_master", "production_plan", "qc_standard", "shipping_requirement"],
      "outputs": ["fulfillment_plan.v1", "qc_report.v1", "logistics_booking_draft.v1", "shipment_status.v1"],
      "control_actions": ["draft_fulfillment_plan", "check_qc", "prepare_shipping_docs", "notify_customer_draft"],
      "required_human_gates": ["approve_production", "approve_qc_release", "approve_shipment_booking"],
      "event_writeback": ["production_started", "qc_passed", "shipment_booked", "shipment_delivered"],
      "audit_evidence": ["qc_photos", "packing_list", "tracking_number", "delivery_record"]
    },
    {
      "node_id": "cbx_13_customs_tax_fx",
      "label": "报关、税务与外汇证据",
      "layer": "compliance",
      "purpose": "检查报关、单证、收汇、退免税和外汇资料完整性。",
      "owner_role": "finance_compliance",
      "status": "draft",
      "source_docs": ["docs/01-mainland-compliance.md", "docs/06-fulfillment-finance-after-sales.md"],
      "inputs": ["order", "invoice", "packing_list", "customs_mode", "payment_record", "shipping_document"],
      "outputs": ["customs_tax_fx_evidence.v1", "document_consistency_report.v1", "filing_blockers.v1"],
      "control_actions": ["check_documents", "draft_customs_pack", "draft_tax_fx_checklist", "block_incomplete_filing"],
      "required_human_gates": ["customs_broker_review", "tax_accountant_review", "bank_fx_review"],
      "event_writeback": ["customs_pack_ready", "tax_fx_blocker_found", "filing_evidence_archived"],
      "audit_evidence": ["customs_declaration", "tax_files", "fx_receipt", "broker_notes"]
    },
    {
      "node_id": "cbx_14_after_sales_retention",
      "label": "售后、复购与客户维护",
      "layer": "customer_success",
      "purpose": "管理到货确认、客诉、满意度、复购提醒、新品推荐和客户分层维护。",
      "owner_role": "customer_success",
      "status": "draft",
      "source_docs": ["docs/06-fulfillment-finance-after-sales.md", "docs/08-customer-ai-examples.md"],
      "inputs": ["delivered_order", "customer_feedback", "issue_report", "purchase_cycle_estimate"],
      "outputs": ["after_sales_record.v1", "retention_trigger_plan.v1", "customer_maintenance_draft.v1"],
      "control_actions": ["collect_issue_evidence", "draft_after_sales_reply", "schedule_reorder_reminder", "draft_reactivation"],
      "required_human_gates": ["approve_compensation", "approve_customer_message"],
      "event_writeback": ["after_sales_opened", "issue_resolved", "reorder_opportunity_created"],
      "audit_evidence": ["customer_photos", "resolution_record", "maintenance_schedule"]
    },
    {
      "node_id": "cbx_15_audit_learning",
      "label": "审计、复盘与自动优化",
      "layer": "audit",
      "purpose": "把渠道、询盘、报价、订单、售后数据转成经营复盘和下一步调度建议。",
      "owner_role": "operator",
      "status": "draft",
      "source_docs": ["docs/07-ai-orchestration.md", "docs/09-roadmap-acceptance.md"],
      "inputs": ["campaign_report", "lead_records", "quote_records", "order_records", "after_sales_records"],
      "outputs": ["weekly_business_dashboard.v1", "optimization_actions.v1", "risk_register.v1"],
      "control_actions": ["build_dashboard", "recommend_next_actions", "update_playbooks", "open_risk_issue"],
      "required_human_gates": ["approve_strategy_change", "approve_budget_change"],
      "event_writeback": ["weekly_review_completed", "playbook_updated", "risk_registered"],
      "audit_evidence": ["dashboard", "decision_log", "before_after_metrics"]
    }
  ]
}
