{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "module-patrol-block.schema.json",
  "title": "Module Patrol Block",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "module_id",
    "display_name",
    "owner",
    "source_dir",
    "gate",
    "compass",
    "patrol_contract_version",
    "lifecycle",
    "updated_at",
    "ttl_ms",
    "change_session_id",
    "data_flow",
    "state",
    "evidence",
    "boundaries",
    "dialogue_limits",
    "versioning"
  ],
  "properties": {
    "schema": {
      "const": "module_patrol_block.v1"
    },
    "module_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "source_dir": {
      "type": "string",
      "minLength": 1
    },
    "process_tree_node_id": {
      "type": ["string", "null"]
    },
    "registration_status": {
      "type": "string"
    },
    "gate": {
      "type": "string",
      "minLength": 1
    },
    "compass": {
      "type": "string",
      "minLength": 1
    },
    "patrol_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle": {
      "enum": ["planned", "designing", "building", "testing", "blocked", "ready", "validated", "deprecated"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "ttl_ms": {
      "type": "integer",
      "minimum": 1000
    },
    "change_session_id": {
      "type": "string",
      "minLength": 1
    },
    "data_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "processing", "outputs", "dependencies"],
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "current_task", "progress", "blockers", "risks", "next"],
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "current_task": {
          "type": "string"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_refs", "validation_commands", "latest_validation_refs"],
      "properties": {
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "latest_validation_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowed_reads", "allowed_writes", "forbidden_actions", "confirmation_gates"],
      "properties": {
        "mode": {
          "enum": ["read_only_summary", "read_only_validation", "controlled_write_runtime_summary"]
        },
        "allowed_reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_writes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmation_gates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dialogue_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["may_say", "must_not_infer"],
      "properties": {
        "may_say": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_not_infer": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "versioning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supersedes",
        "source_hash",
        "source_hash_algorithm",
        "source_hash_generated_at",
        "source_hash_refs",
        "source_hash_excluded_refs"
      ],
      "properties": {
        "supersedes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_hash": {
          "type": "string"
        },
        "source_hash_algorithm": {
          "const": "patrol-source-v1:sha256"
        },
        "source_hash_generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_hash_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_hash_excluded_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
