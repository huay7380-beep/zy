{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-archive.schema.json",
  "title": "SourceArchive",
  "type": "object",
  "required": [
    "schema_version",
    "source_archive_id",
    "source_id",
    "source_type",
    "platform",
    "adapter_id",
    "captured_at",
    "archived_at",
    "source_thread_id",
    "raw_text_ref",
    "raw_payload_ref",
    "checksums_ref",
    "content_hash",
    "privacy_level",
    "delete_state"
  ],
  "properties": {
    "schema_version": { "const": "source_archive.v1" },
    "source_archive_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "adapter_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "minLength": 1 },
    "archived_at": { "type": "string", "minLength": 1 },
    "source_thread_id": { "type": "string", "minLength": 1 },
    "raw_text_ref": { "type": "string", "minLength": 1 },
    "raw_payload_ref": { "type": "string", "minLength": 1 },
    "manifest_ref": { "type": "string" },
    "checksums_ref": { "type": "string", "minLength": 1 },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string", "pattern": "^sha256:" },
    "privacy_level": { "type": "string" },
    "delete_state": { "type": "string", "enum": ["active", "tombstoned"] },
    "archive_dir": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
