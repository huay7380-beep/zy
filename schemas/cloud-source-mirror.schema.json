{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cloud-source-mirror.schema.json",
  "title": "CloudSourceMirror",
  "type": "object",
  "required": [
    "schema_version",
    "mirror_id",
    "created_at",
    "source_root",
    "repository",
    "sync_policy",
    "counts",
    "excluded_large_files"
  ],
  "properties": {
    "schema_version": {
      "const": "cloud_source_mirror.v1"
    },
    "mirror_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_root": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "required": ["owner", "name", "full_name", "url", "local_clone"],
      "properties": {
        "owner": { "type": "string" },
        "name": { "type": "string" },
        "full_name": { "type": "string" },
        "url": { "type": "string" },
        "local_clone": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sync_policy": {
      "type": "object",
      "required": ["mode", "included", "excluded"],
      "properties": {
        "mode": { "type": "string" },
        "included": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": ["candidate_files", "candidate_bytes", "excluded_large_files"],
      "properties": {
        "candidate_files": { "type": "integer", "minimum": 0 },
        "candidate_bytes": { "type": "integer", "minimum": 0 },
        "excluded_large_files": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "excluded_large_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "bytes", "reason"],
        "properties": {
          "path": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

