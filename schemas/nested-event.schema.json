{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/nested-event.schema.json",
  "title": "NestedEvent",
  "type": "object",
  "required": [
    "schema_version",
    "nested_event_id",
    "parent_event_id",
    "raw_event_id",
    "source_archive_id",
    "event_type_code",
    "goal_domain",
    "occurred_at",
    "participants_hint",
    "tags",
    "evidence_refs",
    "evidence_text",
    "requires_confirmation",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "nested_event.v1" },
    "nested_event_id": { "type": "string", "minLength": 1 },
    "parent_event_id": { "type": "string", "minLength": 1 },
    "raw_event_id": { "type": "string", "minLength": 1 },
    "source_archive_id": { "type": "string", "minLength": 1 },
    "event_type_code": { "type": "string", "minLength": 1 },
    "goal_domain": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string" },
    "participants_hint": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence_text": { "type": "string", "minLength": 1 },
    "requires_confirmation": { "type": "boolean" },
    "confirmation_gate_id": { "type": ["string", "null"] },
    "metadata": { "type": "object" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
