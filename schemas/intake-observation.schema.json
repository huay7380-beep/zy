{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntakeObservation",
  "type": "object",
  "required": [
    "observation_id",
    "source_adapter_id",
    "source_type",
    "platform",
    "captured_at",
    "content_summary",
    "privacy_level",
    "confidence"
  ],
  "properties": {
    "observation_id": { "type": "string", "minLength": 1 },
    "source_adapter_id": { "type": "string", "minLength": 1 },
    "source_type": {
      "type": "string",
      "enum": ["desktop", "browser", "api", "file", "ocr", "webhook"]
    },
    "platform": { "type": "string", "minLength": 1 },
    "source_actor_type": {
      "type": "string",
      "enum": ["human_contact", "official_account", "service_account", "group_chat", "system_notification", "unknown"]
    },
    "captured_at": { "type": "string", "minLength": 1 },
    "content_text": { "type": "string" },
    "content_summary": { "type": "string", "minLength": 1 },
    "participants_hint": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_identity_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "identity_type": { "type": "string" },
          "source_actor_type": {
            "type": "string",
            "enum": ["human_contact", "official_account", "service_account", "group_chat", "system_notification", "unknown"]
          },
          "display_name": { "type": "string" },
          "handle": { "type": "string" },
          "value_hash": { "type": "string" },
          "organization_hint": { "type": "string" },
          "thread_key": { "type": "string" },
          "evidence_ref": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": true
      }
    },
    "thread_hint": { "type": "object" },
    "window_ref": { "type": "object" },
    "raw_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "screenshot_hash": { "type": "string" },
    "privacy_level": {
      "type": "string",
      "enum": ["summary_only", "redacted_text", "raw_text_allowed", "artifact_allowed"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
