{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pt028-final-feedback-decision-pack.schema.json",
  "title": "pt028_final_feedback_decision_pack.v1",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "created_at",
    "gate_decision",
    "target_feedback_path",
    "target_feedback_exists",
    "real_execution_allowed",
    "real_send_attempted",
    "writes_real_feedback_target",
    "current_acceptance_summary",
    "artifact_refs",
    "required_human_actions",
    "next_commands",
    "boundary_policy"
  ],
  "properties": {
    "schema_version": { "const": "pt028_final_feedback_decision_pack.v1" },
    "pack_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "enum": [
        "operator_feedback_decision_required",
        "pt028_final_feedback_ready_for_production_acceptance"
      ]
    },
    "root": { "type": "string" },
    "target_feedback_path": { "type": "string" },
    "target_feedback_exists": { "type": "boolean" },
    "real_execution_allowed": { "const": false },
    "real_send_attempted": { "const": false },
    "writes_real_feedback_target": { "const": false },
    "target_write_allowed_by_this_command": { "const": false },
    "current_acceptance_summary": {
      "type": "object",
      "required": [
        "pt028_fully_accepted_for_production",
        "feedback_exists",
        "required_failures"
      ],
      "properties": {
        "chain_id": { "type": ["string", "null"] },
        "gate_decision": { "type": ["string", "null"] },
        "pt028_fully_accepted_for_production": { "type": "boolean" },
        "feedback_exists": { "type": "boolean" },
        "final_acceptance_gate_decision": { "type": ["string", "null"] },
        "required_failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "refreshed_command_results": {
      "type": "object",
      "additionalProperties": true
    },
    "artifact_refs": {
      "type": "object",
      "required": [
        "workpack_json_path",
        "workpack_markdown_path",
        "confirmation_json_path",
        "confirmation_markdown_path",
        "confirmation_decision_template_path",
        "acceptance_chain_json_path",
        "acceptance_chain_markdown_path"
      ],
      "properties": {
        "workpack_json_path": { "type": ["string", "null"] },
        "workpack_markdown_path": { "type": ["string", "null"] },
        "draft_feedback_path": { "type": ["string", "null"] },
        "confirmation_json_path": { "type": ["string", "null"] },
        "confirmation_markdown_path": { "type": ["string", "null"] },
        "confirmation_decision_template_path": { "type": ["string", "null"] },
        "confirmation_preflight_json_path": { "type": ["string", "null"] },
        "confirmation_preflight_markdown_path": { "type": ["string", "null"] },
        "acceptance_chain_json_path": { "type": ["string", "null"] },
        "acceptance_chain_markdown_path": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "evidence_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "operator_feedback_window_checklist": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "pt028_operator_feedback_window_checklist.v1" },
        "source_workpack_path": { "type": ["string", "null"] },
        "required_window_count": { "type": "integer" },
        "required_unique_target_count": { "type": "integer" },
        "observed_candidate_window_count": { "type": "integer" },
        "observed_candidate_unique_target_count": { "type": "integer" },
        "candidate_ready_for_operator_review": { "type": "boolean" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "row_id",
              "slot_index",
              "draft_record_pointer",
              "operator_must_confirm",
              "confirmation_status",
              "candidate_prefill_only"
            ],
            "properties": {
              "row_id": { "type": "string" },
              "slot_index": { "type": "integer" },
              "task_id": { "type": ["string", "null"] },
              "required": { "type": "boolean" },
              "app_type": { "type": "string" },
              "draft_record_pointer": { "type": "string" },
              "window_id": { "type": ["string", "null"] },
              "target_person_id": { "type": ["string", "null"] },
              "target_display_name_hint": { "type": ["string", "null"] },
              "state_path": { "type": ["string", "null"] },
              "dock_status_text": { "type": ["string", "null"] },
              "send_gate_mode": { "type": ["string", "null"] },
              "evidence_refs": { "type": "array", "items": { "type": "string" } },
              "operator_must_confirm": { "type": "array", "items": { "type": "string" } },
              "confirmation_status": { "type": "object", "additionalProperties": true },
              "ready_for_real_feedback_target_write": { "type": "boolean" },
              "candidate_prefill_only": { "const": true },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "boundary_policy": {
          "type": "object",
          "properties": {
            "candidate_prefill_only": { "const": true },
            "operator_confirmation_required": { "const": true },
            "preflight_required_before_target_write": { "const": true },
            "real_send_allowed": { "const": false }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "output_paths": {
      "type": "object",
      "properties": {
        "json_path": { "type": "string" },
        "markdown_path": { "type": "string" },
        "html_path": { "type": "string" },
        "latest_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "required_human_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "title",
          "status",
          "owner",
          "fields_to_complete",
          "evidence"
        ],
        "properties": {
          "action_id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "owner": { "type": "string" },
          "artifact_path": { "type": ["string", "null"] },
          "fields_to_complete": {
            "type": "array",
            "items": { "type": "string" }
          },
          "command_after_completion": { "type": ["string", "null"] },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "next_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "boundary_policy": {
      "type": "object",
      "required": [
        "command_is_read_only_to_target_feedback_file",
        "real_feedback_target_writer",
        "real_execution_allowed",
        "real_send_attempted",
        "candidate_observations_are_not_final_feedback"
      ],
      "properties": {
        "command_is_read_only_to_target_feedback_file": { "const": true },
        "real_feedback_target_writer": { "type": "string" },
        "real_execution_allowed": { "const": false },
        "real_send_attempted": { "const": false },
        "candidate_observations_are_not_final_feedback": { "const": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
