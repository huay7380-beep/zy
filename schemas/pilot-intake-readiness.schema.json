{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PilotIntakeReadiness",
  "type": "object",
  "required": [
    "schema_version",
    "readiness_id",
    "created_at",
    "import_id",
    "gate_decision",
    "ready_for_decision_trial",
    "ready_for_closed_loop_mvp",
    "thresholds",
    "metrics",
    "checks",
    "required_failures",
    "recommended_failures",
    "missing_materials",
    "next_commands"
  ],
  "properties": {
    "schema_version": { "const": "pilot_intake_readiness.v1" },
    "readiness_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "import_id": { "type": "string", "minLength": 1 },
    "input_path": { "type": ["string", "null"] },
    "gate_decision": {
      "type": "string",
      "enum": [
        "continue_to_mvp_closed_loop",
        "run_decision_trial_collect_feedback_before_closed_loop",
        "stop_and_fix_intake"
      ]
    },
    "ready_for_decision_trial": { "type": "boolean" },
    "ready_for_closed_loop_mvp": { "type": "boolean" },
    "thresholds": {
      "type": "object",
      "required": [
        "min_raw_events",
        "min_semantic_coverage",
        "max_single_client_minutes"
      ],
      "properties": {
        "min_raw_events": { "type": "number" },
        "min_semantic_coverage": { "type": "number" },
        "max_single_client_minutes": { "type": "number" }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": [
        "people_count",
        "relationship_count",
        "raw_event_count",
        "semantic_event_count",
        "semantic_coverage",
        "feedback_count",
        "estimated_single_client_minutes",
        "linked_raw_event_ratio",
        "semantic_relationship_link_count"
      ],
      "properties": {
        "people_count": { "type": "number" },
        "relationship_count": { "type": "number" },
        "raw_event_count": { "type": "number" },
        "semantic_event_count": { "type": "number" },
        "semantic_coverage": { "type": "number" },
        "feedback_count": { "type": "number" },
        "source_breakdown": { "type": "object" },
        "record_time_span": {
          "anyOf": [
            {
              "type": "object",
              "required": ["start_at", "end_at"],
              "properties": {
                "start_at": { "type": "string" },
                "end_at": { "type": "string" }
              },
              "additionalProperties": true
            },
            { "type": "null" }
          ]
        },
        "estimated_single_client_minutes": { "type": "number" },
        "linked_raw_event_ratio": { "type": "number" },
        "semantic_relationship_link_count": { "type": "number" }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "severity",
          "status",
          "passed"
        ],
        "properties": {
          "check_id": { "type": "string" },
          "label": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["required", "recommended"]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "passed": { "type": "boolean" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fix": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "required_failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "severity"],
        "properties": {
          "check_id": { "type": "string" },
          "severity": { "type": "string" },
          "fix": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "continue_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_or_adjust_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_commands": {
      "type": "object",
      "required": [
        "validate_intake",
        "dry_run_import",
        "run_mvp",
        "audit_after_run"
      ],
      "properties": {
        "validate_intake": { "type": "string" },
        "dry_run_import": { "type": "string" },
        "run_mvp": { "type": "string" },
        "audit_after_run": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
