{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/mvp-objective-audit.schema.json",
  "title": "MvpObjectiveAudit",
  "type": "object",
  "required": [
    "schema_version",
    "audit_id",
    "created_at",
    "objective",
    "objective_status",
    "ready_for_user_special_testing",
    "ready_to_expand_sample_or_real_connector",
    "source",
    "checks",
    "required_failures",
    "expansion_failures",
    "external_input_status",
    "continue_when",
    "stop_or_adjust_when",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "mvp_objective_audit.v1" },
    "audit_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "objective_status": {
      "type": "string",
      "enum": [
        "objective_evidence_incomplete",
        "local_objective_evidence_complete_waiting_external_inputs",
        "real_inputs_ready_waiting_real_trial",
        "real_trial_complete_waiting_issue_register_review",
        "objective_ready_to_expand_sample_or_real_connector"
      ]
    },
    "ready_for_user_special_testing": { "type": "boolean" },
    "ready_to_expand_sample_or_real_connector": { "type": "boolean" },
    "source": {
      "type": "object",
      "required": ["preflight_path", "completion_audit_path"],
      "properties": {
        "root": { "type": "string" },
        "preflight_path": { "type": ["string", "null"] },
        "completion_audit_path": { "type": ["string", "null"] },
        "run_id": { "type": ["string", "null"] },
        "report_path": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "label", "severity", "status", "passed", "evidence"],
        "properties": {
          "check_id": { "type": "string" },
          "label": { "type": "string" },
          "severity": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "passed": { "type": "boolean" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "next_action": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "required_failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expansion_failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_input_status": {
      "type": "object",
      "required": ["gate_decision", "ready_for_real_input_trial", "required_failures", "item_results"],
      "properties": {
        "gate_decision": { "type": "string" },
        "ready_for_real_input_trial": { "type": "boolean" },
        "required_failures": { "type": "array", "items": { "type": "string" } },
        "item_results": { "type": "array" }
      },
      "additionalProperties": true
    },
    "continue_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_or_adjust_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
