{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/summary-shard.schema.json",
  "title": "SummaryShard",
  "type": "object",
  "required": [
    "schema_version",
    "summary_shard_id",
    "shard_type",
    "source_refs",
    "subject_refs",
    "summary_text",
    "tags",
    "replaces_original",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "summary_shard.v1" },
    "summary_shard_id": { "type": "string", "minLength": 1 },
    "shard_type": {
      "type": "string",
      "enum": ["person_summary", "event_summary", "time_window_summary", "goal_domain_summary", "tag_summary", "thread_summary"]
    },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "subject_refs": { "type": "array", "items": { "type": "string" } },
    "time_window": { "type": ["object", "null"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "replaces_original": { "const": false },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
