{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/read-only-source-collection-manifest.schema.json",
  "title": "ReadOnlySourceCollectionManifest",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": "read_only_source_collection_manifest.v1" },
    "collection_id": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "source_kind"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "source_kind": {
            "type": "string",
            "enum": [
              "external_chat_export",
              "chat_export",
              "external_chat",
              "external_chat_file",
              "browser_html",
              "web_html",
              "saved_page_html",
              "browser",
              "business_api_snapshot",
              "business_api",
              "api_snapshot",
              "business_snapshot"
            ]
          },
          "file": { "type": "string" },
          "path": { "type": "string" },
          "html": { "type": "string" },
          "json": { "type": "string" },
          "export_path": { "type": "string" },
          "snapshot_path": { "type": "string" },
          "thread_title": { "type": "string" },
          "thread_id": { "type": "string" },
          "participants": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            ]
          },
          "participant_hints": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            ]
          },
          "adapter_id": { "type": "string" },
          "platform": { "type": "string" },
          "privacy_level": {
            "type": "string",
            "enum": ["summary_only", "redacted_text", "raw_text_allowed", "artifact_allowed"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "url": { "type": "string" },
          "page_url": { "type": "string" },
          "endpoint": { "type": "string" },
          "record_id": { "type": "string" }
        },
        "anyOf": [
          { "required": ["file"] },
          { "required": ["path"] },
          { "required": ["html"] },
          { "required": ["json"] },
          { "required": ["export_path"] },
          { "required": ["snapshot_path"] }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
