{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/identity-resolution-audit.schema.json",
  "title": "IdentityResolutionAudit",
  "type": "object",
  "required": [
    "schema_version",
    "audit_id",
    "created_at",
    "gate_decision",
    "checks",
    "required_failures",
    "warning_failures",
    "artifacts",
    "gap_review"
  ],
  "properties": {
    "schema_version": { "const": "identity_resolution_audit.v1" },
    "audit_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "type": "string",
      "enum": ["identity_resolution_ready", "identity_resolution_blocked"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "severity", "status", "passed", "evidence"],
        "properties": {
          "check_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["required", "warning"] },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "passed": { "type": "boolean" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "fix": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "required_failures": { "type": "array", "items": { "type": "string" } },
    "warning_failures": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "object", "additionalProperties": true },
    "gap_review": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
