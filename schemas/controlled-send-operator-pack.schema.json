{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ControlledSendOperatorPack",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "created_at",
    "gate_decision",
    "real_send_attempted",
    "real_send_verified",
    "simulation_goal_complete",
    "docs16_goal_complete",
    "operator_inputs",
    "current_blockers",
    "latest_artifacts",
    "operator_actions",
    "safety_gates",
    "output_dir"
  ],
  "properties": {
    "schema_version": { "const": "controlled_send_operator_pack.v1" },
    "pack_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "type": "string",
      "enum": [
        "operator_pack_waiting_for_reviewed_decision",
        "operator_pack_ready_for_prepare",
        "operator_pack_ready_for_runner",
        "operator_pack_real_send_verified"
      ]
    },
    "real_send_attempted": { "const": false },
    "real_send_verified": { "type": "boolean" },
    "simulation_goal_complete": { "type": "boolean" },
    "docs16_goal_complete": { "type": "boolean" },
    "operator_inputs": {
      "type": "object",
      "required": [
        "command_draft_path",
        "command_draft_report_path",
        "reviewed_decision_template_path",
        "reviewed_decision_user_input_template_path",
        "reviewed_decision_target_path",
        "command_target_path",
        "box_regions_template_path",
        "box_regions_target_path"
      ],
      "properties": {
        "command_draft_path": { "type": ["string", "null"] },
        "command_draft_report_path": { "type": ["string", "null"] },
        "reviewed_decision_template_path": { "type": ["string", "null"] },
        "reviewed_decision_user_input_template_path": { "type": ["string", "null"] },
        "reviewed_decision_target_path": { "type": "string", "minLength": 1 },
        "command_target_path": { "type": "string", "minLength": 1 },
        "box_regions_template_path": { "type": "string", "minLength": 1 },
        "box_regions_target_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "current_blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "latest_artifacts": {
      "type": "object",
      "required": [
        "material_kit",
        "command_draft",
        "command_confirmation",
        "command_preflight",
        "desktop_trial",
        "real_window_readiness",
        "handoff",
        "intake_audit",
        "docs16_status"
      ],
      "properties": {
        "material_kit": { "type": ["object", "null"] },
        "command_draft": { "type": ["object", "null"] },
        "command_confirmation": { "type": ["object", "null"] },
        "command_preflight": { "type": ["object", "null"] },
        "desktop_trial": { "type": ["object", "null"] },
        "real_window_readiness": { "type": ["object", "null"] },
        "handoff": { "type": ["object", "null"] },
        "intake_audit": { "type": ["object", "null"] },
        "docs16_status": { "type": ["object", "null"] }
      },
      "additionalProperties": false
    },
    "operator_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "status",
          "description",
          "command",
          "input_path",
          "output_path",
          "evidence_refs",
          "blockers"
        ],
        "properties": {
          "action_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pending", "blocked", "ready", "complete"]
          },
          "description": { "type": "string", "minLength": 1 },
          "command": { "type": ["string", "null"] },
          "input_path": { "type": ["string", "null"] },
          "output_path": { "type": ["string", "null"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "safety_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "output_dir": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
