{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-episode.schema.json",
  "title": "SourceEpisode",
  "type": "object",
  "required": [
    "schema_version",
    "episode_id",
    "source_archive_id",
    "source_type",
    "platform",
    "thread_id",
    "captured_at",
    "time_window",
    "participants_hint",
    "raw_event_ids",
    "content_fingerprint",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "source_episode.v1" },
    "episode_id": { "type": "string", "minLength": 1 },
    "source_archive_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string" },
    "platform": { "type": "string" },
    "thread_id": { "type": "string" },
    "captured_at": { "type": "string" },
    "time_window": { "type": "string" },
    "participants_hint": { "type": "array", "items": { "type": "string" } },
    "source_identity_hints": { "type": "array", "items": { "type": "object" } },
    "raw_event_ids": { "type": "array", "items": { "type": "string" } },
    "content_fingerprint": { "type": "string", "pattern": "^sha256:" },
    "status": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
