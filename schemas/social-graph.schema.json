{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SocialGraphSnapshot",
  "type": "object",
  "required": ["user_id", "people", "relationships", "events"],
  "properties": {
    "user_id": { "type": "string" },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["person_id", "display_name"],
        "properties": {
          "person_id": { "type": "string" },
          "display_name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "visibility": { "type": "string", "enum": ["private", "contacts_only", "public"] },
          "notes": { "type": "string" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relationship_id", "from_person_id", "to_person_id", "type_code"],
        "properties": {
          "relationship_id": { "type": "string" },
          "from_person_id": { "type": "string" },
          "to_person_id": { "type": "string" },
          "type_code": { "type": "string" },
          "dimension": { "type": "integer", "minimum": 0, "maximum": 5 },
          "weights": {
            "type": "object",
            "properties": {
              "from_to": { "type": "number", "minimum": 0, "maximum": 1 },
              "to_from": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "phase": { "type": "string" },
          "trust_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "sentiment_trend": { "type": "string", "enum": ["down", "stable", "up"] },
          "health_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "recent_interactions": { "type": "array" },
          "visibility": { "type": "string", "enum": ["private", "contacts_only", "public"] }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "event_type_code", "start_at", "status"],
        "properties": {
          "event_id": { "type": "string" },
          "event_type_code": { "type": "string" },
          "event_level": { "type": "string", "enum": ["P1", "P2", "P3"] },
          "start_at": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "ongoing", "completed", "cancelled"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "importance": { "type": "number", "minimum": 0, "maximum": 1 },
          "sentiment_score": { "type": "number", "minimum": -1, "maximum": 1 },
          "source": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "participants": { "type": "array" },
          "clues": { "type": "array" }
        }
      }
    }
  }
}
