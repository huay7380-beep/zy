{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pt028-feedback-collection-coverage.schema.json",
  "title": "pt028_feedback_collection_coverage.v1",
  "type": "object",
  "required": [
    "schema_version",
    "coverage_id",
    "created_at",
    "gate_decision",
    "ready_for_confirmation_preflight",
    "real_execution_allowed",
    "real_send_attempted",
    "writes_real_feedback_target",
    "source",
    "linked_session",
    "linked_decision",
    "coverage_summary",
    "task_coverage",
    "checks",
    "required_failures",
    "boundary_policy"
  ],
  "properties": {
    "schema_version": { "const": "pt028_feedback_collection_coverage.v1" },
    "coverage_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "enum": [
        "ready_for_confirmation_preflight",
        "collection_coverage_needs_attention"
      ]
    },
    "ready_for_confirmation_preflight": { "type": "boolean" },
    "real_execution_allowed": { "const": false },
    "real_send_attempted": { "const": false },
    "writes_real_feedback_target": { "const": false },
    "source": {
      "type": "object",
      "required": ["root", "session_path", "decision_path", "output_dir"],
      "properties": {
        "root": { "type": "string" },
        "session_path": { "type": ["string", "null"] },
        "decision_path": { "type": ["string", "null"] },
        "output_dir": { "type": "string" }
      },
      "additionalProperties": true
    },
    "linked_session": {
      "type": "object",
      "properties": {
        "session_id": { "type": ["string", "null"] },
        "gate_decision": { "type": ["string", "null"] },
        "ready_for_operator_feedback_collection": { "type": "boolean" },
        "task_count": { "type": "integer" },
        "distinct_target_count": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "linked_decision": {
      "type": "object",
      "properties": {
        "decision_id": { "type": ["string", "null"] },
        "schema_version": { "type": ["string", "null"] },
        "record_count": { "type": "integer" },
        "approved_to_write_real_feedback_target": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "coverage_summary": {
      "type": "object",
      "required": [
        "task_count",
        "record_count",
        "matched_task_count",
        "confirmed_task_count",
        "unmatched_task_ids",
        "unconfirmed_task_ids"
      ],
      "properties": {
        "task_count": { "type": "integer" },
        "record_count": { "type": "integer" },
        "matched_task_count": { "type": "integer" },
        "confirmed_task_count": { "type": "integer" },
        "unmatched_task_ids": { "type": "array", "items": { "type": "string" } },
        "unconfirmed_task_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "task_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "status", "record_pointer", "checks"],
        "properties": {
          "task_id": { "type": "string" },
          "status": { "enum": ["covered_and_confirmed", "covered_but_unconfirmed", "missing_or_mismatched"] },
          "record_pointer": { "type": "string" },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["check_id", "status"],
              "properties": {
                "check_id": { "type": "string" },
                "status": { "enum": ["passed", "failed"] },
                "evidence": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status", "required", "evidence"],
        "properties": {
          "check_id": { "type": "string" },
          "status": { "enum": ["passed", "failed"] },
          "required": { "type": "boolean" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "required_failures": { "type": "array", "items": { "type": "string" } },
    "warning_failures": { "type": "array", "items": { "type": "string" } },
    "next_commands": { "type": "array", "items": { "type": "string" } },
    "boundary_policy": {
      "type": "object",
      "required": [
        "coverage_check_is_read_only",
        "real_execution_allowed",
        "real_send_attempted",
        "writes_real_feedback_target"
      ],
      "properties": {
        "coverage_check_is_read_only": { "const": true },
        "real_execution_allowed": { "const": false },
        "real_send_attempted": { "const": false },
        "writes_real_feedback_target": { "const": false }
      },
      "additionalProperties": true
    },
    "output_paths": {
      "type": "object",
      "properties": {
        "json_path": { "type": "string" },
        "markdown_path": { "type": "string" },
        "latest_path": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
