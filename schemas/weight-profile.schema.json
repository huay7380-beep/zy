{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/weight-profile.schema.json",
  "title": "WeightProfile",
  "type": "object",
  "required": [
    "schema_version",
    "weight_profile_id",
    "subject_ref",
    "subject_type",
    "rule_version",
    "intrinsic_weight",
    "contextual_weight",
    "visual_weight",
    "weight_level",
    "confirmation_need",
    "calculation_basis",
    "writes_fact_state",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "weight_profile.v1" },
    "weight_profile_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "subject_type": { "type": "string", "minLength": 1 },
    "rule_version": { "type": "string", "minLength": 1 },
    "intrinsic_weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "contextual_weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "visual_weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "weight_level": { "type": "string", "enum": ["V0", "V1", "V2", "V3", "V4", "V5"] },
    "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_reliability": { "type": "number", "minimum": 0, "maximum": 1 },
    "event_impact": { "type": "number", "minimum": 0, "maximum": 1 },
    "goal_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
    "relationship_impact": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_priority": { "type": "number", "minimum": 0, "maximum": 1 },
    "recency": { "type": "number", "minimum": 0, "maximum": 1 },
    "confirmation_need": { "type": "number", "minimum": 0, "maximum": 1 },
    "calculation_basis": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "writes_fact_state": { "const": false },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
