{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pt028-feedback-collection-session.schema.json",
  "title": "pt028_feedback_collection_session.v1",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "created_at",
    "gate_decision",
    "ready_for_operator_feedback_collection",
    "real_execution_allowed",
    "real_send_attempted",
    "writes_real_feedback_target",
    "source",
    "linked_handoff",
    "linked_pack",
    "collection_scope",
    "operator_collection_tasks",
    "checks",
    "required_failures",
    "boundary_policy"
  ],
  "properties": {
    "schema_version": { "const": "pt028_feedback_collection_session.v1" },
    "session_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "enum": [
        "ready_for_operator_window_feedback_collection",
        "feedback_collection_session_needs_attention"
      ]
    },
    "ready_for_operator_feedback_collection": { "type": "boolean" },
    "real_execution_allowed": { "const": false },
    "real_send_attempted": { "const": false },
    "writes_real_feedback_target": { "const": false },
    "source": {
      "type": "object",
      "required": ["root", "handoff_path", "pack_path", "output_dir"],
      "properties": {
        "root": { "type": "string" },
        "handoff_path": { "type": ["string", "null"] },
        "pack_path": { "type": ["string", "null"] },
        "output_dir": { "type": "string" }
      },
      "additionalProperties": true
    },
    "linked_handoff": {
      "type": "object",
      "properties": {
        "validation_id": { "type": ["string", "null"] },
        "gate_decision": { "type": ["string", "null"] },
        "ready_for_operator_feedback_collection": { "type": "boolean" },
        "required_failures": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "linked_pack": {
      "type": "object",
      "properties": {
        "pack_id": { "type": ["string", "null"] },
        "gate_decision": { "type": ["string", "null"] },
        "target_feedback_path": { "type": ["string", "null"] },
        "target_feedback_exists": { "type": "boolean" },
        "decision_template_path": { "type": ["string", "null"] },
        "html_path": { "type": ["string", "null"] },
        "draft_feedback_path": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "collection_scope": {
      "type": "object",
      "required": [
        "required_window_count",
        "required_unique_target_count",
        "task_count",
        "distinct_target_count",
        "candidate_prefill_only",
        "all_real_send_disallowed"
      ],
      "properties": {
        "required_window_count": { "type": "integer" },
        "required_unique_target_count": { "type": "integer" },
        "task_count": { "type": "integer" },
        "distinct_target_count": { "type": "integer" },
        "candidate_prefill_only": { "type": "boolean" },
        "all_real_send_disallowed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "operator_collection_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "checklist_row_id",
          "slot_index",
          "draft_record_pointer",
          "decision_template_record_pointer",
          "required_operator_confirmations",
          "candidate_prefill_only",
          "real_send_allowed",
          "status"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "checklist_row_id": { "type": "string" },
          "slot_index": { "type": "integer" },
          "app_type": { "type": ["string", "null"] },
          "window_id": { "type": ["string", "null"] },
          "target_person_id": { "type": ["string", "null"] },
          "target_display_name_hint": { "type": ["string", "null"] },
          "draft_record_pointer": { "type": "string" },
          "decision_template_record_pointer": { "type": "string" },
          "state_path": { "type": ["string", "null"] },
          "dock_status_text": { "type": ["string", "null"] },
          "send_gate_mode": { "type": ["string", "null"] },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "required_operator_confirmations": { "type": "array", "items": { "type": "string" } },
          "capture_prompts": { "type": "array", "items": { "type": "string" } },
          "candidate_prefill_only": { "const": true },
          "real_send_allowed": { "const": false },
          "ready_for_real_feedback_target_write": { "const": false },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status", "required", "evidence"],
        "properties": {
          "check_id": { "type": "string" },
          "status": { "enum": ["passed", "failed"] },
          "required": { "type": "boolean" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "required_failures": { "type": "array", "items": { "type": "string" } },
    "warning_failures": { "type": "array", "items": { "type": "string" } },
    "next_commands": { "type": "array", "items": { "type": "string" } },
    "boundary_policy": {
      "type": "object",
      "required": [
        "session_is_read_only",
        "operator_confirmation_required",
        "preflight_required_before_target_write",
        "real_execution_allowed",
        "real_send_attempted",
        "writes_real_feedback_target"
      ],
      "properties": {
        "session_is_read_only": { "const": true },
        "operator_confirmation_required": { "const": true },
        "preflight_required_before_target_write": { "const": true },
        "real_execution_allowed": { "const": false },
        "real_send_attempted": { "const": false },
        "writes_real_feedback_target": { "const": false }
      },
      "additionalProperties": true
    },
    "output_paths": {
      "type": "object",
      "properties": {
        "json_path": { "type": "string" },
        "markdown_path": { "type": "string" },
        "html_path": { "type": "string" },
        "latest_path": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
