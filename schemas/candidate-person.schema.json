{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidatePerson",
  "type": "object",
  "required": [
    "candidate_person_id",
    "display_name",
    "status",
    "confidence",
    "channel_identity_ids",
    "evidence_refs",
    "tags",
    "role_hints",
    "requires_user_confirmation",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "candidate_person_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "normalized_display_name": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["candidate", "confirmed", "rejected", "merged"]
    },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "channel_identity_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_observation_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "role_hints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "organization_hint": { "type": ["string", "null"] },
    "thread_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requires_user_confirmation": { "type": "boolean" },
    "confirmed_person_id": { "type": ["string", "null"] },
    "confirmed_at": { "type": ["string", "null"] },
    "metadata": { "type": "object" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
