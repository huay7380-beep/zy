{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/pilot-feedback-append.schema.json",
  "title": "PilotFeedbackAppend",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "created_at",
    "gate_decision",
    "real_execution_allowed",
    "real_send_attempted",
    "source",
    "before_readiness",
    "template",
    "required_failures",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "pilot_feedback_append.v1" },
    "report_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "gate_decision": {
      "enum": [
        "feedback_template_written_no_import_changed",
        "pilot_feedback_appended_ready_for_closed_loop",
        "pilot_feedback_appended_needs_attention"
      ]
    },
    "real_execution_allowed": { "const": false },
    "real_send_attempted": { "const": false },
    "source": {
      "type": "object",
      "required": ["pilot_import_path", "feedback_path"],
      "properties": {
        "pilot_import_path": { "type": "string", "minLength": 1 },
        "feedback_path": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "before_readiness": { "$ref": "#/$defs/readiness_summary" },
    "after_readiness": {
      "anyOf": [
        { "$ref": "#/$defs/readiness_summary" },
        { "type": "null" }
      ]
    },
    "appended_feedback": {
      "anyOf": [
        {
          "type": "object",
          "required": ["feedback_id", "executed", "reply_received", "goal_progress", "user_rating"],
          "additionalProperties": true
        },
        { "type": "null" }
      ]
    },
    "updated_pilot_import": {
      "anyOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "null" }
      ]
    },
    "template": {
      "type": "object",
      "required": ["feedback_id", "executed", "reply_received", "goal_progress", "user_rating", "metadata"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["template_only", "real_execution_allowed", "real_send_attempted"],
          "properties": {
            "template_only": { "const": true },
            "real_execution_allowed": { "const": false },
            "real_send_attempted": { "const": false }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "required_failures": { "type": "array", "items": { "type": "string" } },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "readiness_summary": {
      "type": "object",
      "required": [
        "gate_decision",
        "ready_for_decision_trial",
        "ready_for_closed_loop_mvp",
        "required_failures",
        "recommended_failures",
        "metrics"
      ],
      "properties": {
        "gate_decision": { "type": "string", "minLength": 1 },
        "ready_for_decision_trial": { "type": "boolean" },
        "ready_for_closed_loop_mvp": { "type": "boolean" },
        "required_failures": { "type": "array", "items": { "type": "string" } },
        "recommended_failures": { "type": "array", "items": { "type": "string" } },
        "metrics": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
