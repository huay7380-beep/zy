{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/person-identity-link.schema.json",
  "title": "PersonIdentityLink",
  "type": "object",
  "required": [
    "link_id",
    "person_id",
    "channel_identity_id",
    "platform",
    "status",
    "confidence",
    "verified",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "link_id": { "type": "string", "minLength": 1 },
    "person_id": { "type": "string", "minLength": 1 },
    "channel_identity_id": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["candidate", "confirmed", "rejected"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verified": { "type": "boolean" },
    "confirmed_by": { "type": ["string", "null"] },
    "confirmed_at": { "type": ["string", "null"] },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "thread_keys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
