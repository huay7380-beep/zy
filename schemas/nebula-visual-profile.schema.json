{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/nebula-visual-profile.schema.json",
  "title": "NebulaVisualProfile",
  "type": "object",
  "required": [
    "schema_version",
    "projection_id",
    "node_id",
    "visual_weight_level",
    "node_size",
    "brightness",
    "opacity",
    "color_channel",
    "border_style",
    "pulse_state",
    "label_priority",
    "explainability"
  ],
  "properties": {
    "schema_version": { "const": "nebula_visual_profile.v1" },
    "projection_id": { "type": "string", "minLength": 1 },
    "node_id": { "type": "string", "minLength": 1 },
    "source_weight_profile_ref": { "type": ["string", "null"] },
    "visual_weight_level": { "type": "string", "enum": ["V0", "V1", "V2", "V3", "V4", "V5"] },
    "node_size": { "type": "number", "minimum": 0 },
    "brightness": { "type": "number", "minimum": 0, "maximum": 1 },
    "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
    "color_channel": { "type": "string" },
    "border_style": { "type": "string" },
    "pulse_state": { "type": "string" },
    "edge_thickness": { "type": "number" },
    "label_priority": { "type": "string" },
    "explainability": { "type": "object" }
  },
  "additionalProperties": true
}
