{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ColdStartPersonIntroduction",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "gate_decision",
    "real_execution_allowed",
    "real_send_attempted",
    "summary",
    "candidates",
    "role_bindings",
    "scene_relationship_weights"
  ],
  "properties": {
    "schema_version": { "const": "cold_start_person_introduction.v1" },
    "report_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "gate_decision": { "const": "cold_start_candidates_ready_for_confirmation" },
    "real_execution_allowed": { "const": false },
    "real_send_attempted": { "const": false },
    "summary": {
      "type": "object",
      "required": [
        "observations",
        "manual_people",
        "candidate_people",
        "role_bindings",
        "scene_relationship_weights"
      ],
      "properties": {
        "observations": { "type": "integer", "minimum": 0 },
        "manual_people": { "type": "integer", "minimum": 0 },
        "candidate_people": { "type": "integer", "minimum": 0 },
        "role_bindings": { "type": "integer", "minimum": 0 },
        "scene_relationship_weights": { "type": "integer", "minimum": 0 },
        "known_confirmed_persons_skipped": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "./candidate-person.schema.json" }
    },
    "role_bindings": {
      "type": "array",
      "items": { "$ref": "./person-role-binding.schema.json" }
    },
    "scene_relationship_weights": {
      "type": "array",
      "items": { "$ref": "./scene-relationship-weight.schema.json" }
    },
    "operator_next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
